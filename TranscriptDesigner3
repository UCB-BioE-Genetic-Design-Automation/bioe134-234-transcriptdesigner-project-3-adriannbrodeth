import random
import csv
from genedesign.rbs_chooser import RBSChooser
from genedesign.models.transcript import Transcript

# Importing the provided checker tools
from genedesign.rbs_chooser import RBSChooser
from genedesign.models.transcript import Transcript
from genedesign.checkers.codon_checker import CodonChecker
from genedesign.checkers.forbidden_sequence_checker import ForbiddenSequenceChecker
from genedesign.checkers.hairpin_checker import hairpin_checker
from genedesign.checkers.internal_promoter_checker import PromoterChecker

class TranscriptDesigner:
    """
    An improved TranscriptDesigner that uses randomized codon selection and 
    iterative validation to satisfy CAI, hairpin, promoter, and forbidden sequence constraints.
    """

    def __init__(self):
        self.rbsChooser = None
        self.promoterChecker = PromoterChecker()
        self.forbiddenChecker = ForbiddenSequenceChecker()
        self.codonChecker = CodonChecker()
        self.aminoAcidToCodonMap = {}

    def initiate(self) -> None:
        """
        Initializes the codon table from the txt file and the validation checkers.
        """
        self.rbsChooser = RBSChooser()
        self.rbsChooser.initiate()
        self.promoterChecker.initiate()
        self.forbiddenChecker.initiate()
        self.codonChecker.initiate()

        # Load codon usage data from the provided file
        # Format expected: Codon | AA | Frequency | Count
        codon_usage_file = 'genedesign/data/codon_usage.txt'
        try:
            with open(codon_usage_file, 'r') as f:
                for line in f:
                    parts = line.split()
                    if len(parts) >= 3:
                        codon = parts[0].strip()
                        aa = parts[1].strip()
                        freq = float(parts[2].strip())
                        
                        if aa not in self.aminoAcidToCodonMap:
                            self.aminoAcidToCodonMap[aa] = []
                        self.aminoAcidToCodonMap[aa].append((codon, freq))
        except FileNotFoundError:
            print(f"Warning: {codon_usage_file} not found. Ensure the directory structure is correct.")

    def _generate_candidate_codons(self, peptide: str) -> list:
        """
        Generates a codon list by picking codons based on their frequency weights.
        """
        codons = []
        for aa in peptide:
            options = self.aminoAcidToCodonMap.get(aa)
            if not options:
                continue
            
            # Weighted random choice based on usage frequency
            choices = [opt[0] for opt in options]
            weights = [opt[1] for opt in options]
            codons.append(random.choices(choices, weights=weights)[0])
        
        codons.append("TAA")  # Standard stop codon [cite: 1]
        return codons

    def run(self, peptide: str, ignores: set, max_attempts: int = 200) -> Transcript:
        """
        Translates the peptide to DNA by iterating until all constraints are met.
        """
        for attempt in range(max_attempts):
            # 1. Generate a candidate sequence
            codons = self._generate_candidate_codons(peptide)
            cds_seq = "".join(codons)
            
            # 2. Validate Codon Usage (CAI, Diversity, Rare Codons)
            c_pass, div, rare, cai = self.codon_checker.run(codons)
            if not c_pass:
                continue
                
            # 3. Validate Forbidden Sequences
            f_pass, forbidden_site = self.forbiddenChecker.run(cds_seq)
            if not f_pass:
                continue
                
            # 4. Validate Internal Promoters [cite: 2]
            p_pass, promoter_seq = self.promoterChecker.run(cds_seq)
            if not p_pass:
                continue
                
            # 5. Validate Hairpin Count [cite: 3]
            h_pass, hairpin_str = hairpin_checker(cds_seq)
            if not h_pass:
                continue
            
            # 6. Finalize: Choose RBS and return Transcript [cite: 1]
            selectedRBS = self.rbsChooser.run(cds_seq, ignores)
            print(f"Design Success on attempt {attempt+1} (CAI: {cai:.3f})")
            return Transcript(selectedRBS, peptide, codons)

        raise Exception(f"Failed to find a valid sequence for peptide '{peptide}' after {max_attempts} attempts.")

if __name__ == "__main__":
    designer = TranscriptDesigner()
    designer.initiate()

    peptide = "MYPFIRTARMTV"
    try:
        transcript = designer.run(peptide, set())
        print(f"\nFinal Result:\nRBS: {transcript.rbs}\nCDS: {''.join(transcript.codons)}")
    except Exception as e:
        print(e)